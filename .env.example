# .env - Bot Credentials & Settings
# IMPORTANT: Do NOT commit this file to git! Add to .gitignore
# Copy this to .env and fill in your actual values

# Account Credentials
# Format: USERNAME_N and PASSWORD_N (N = account number)
# Example with 5 accounts:
USERNAME_1=AltAccount1
PASSWORD_1=your_password_here

USERNAME_2=AltAccount2
PASSWORD_2=your_password_here

USERNAME_3=AltAccount3
PASSWORD_3=your_password_here

USERNAME_4=AltAccount4
PASSWORD_4=your_password_here

USERNAME_5=AltAccount5
PASSWORD_5=your_password_here

# Which accounts to use - SUPPORTS RANGES!
# Examples:
#   "1"          = use account 1 only
#   "1,3,5"      = use accounts 1, 3, and 5
#   "1-5"        = use accounts 1, 2, 3, 4, 5
#   "1-3,5,7-9"  = use accounts 1, 2, 3, 5, 7, 8, 9 (mixed ranges and singles)
ACTIVE_ACCOUNTS=1-2

# Server connection
SERVER=alt.6b6t.org

# Skip login command (set to "true" if server uses auto-login)
SKIP_LOGIN=false

# Start building immediately when bot joins
# "true" = start building, "false" = wait for manual command
START_BUILDING_ON_JOIN=false

# === WHITELIST CONFIGURATION ===
# Add whitelisted usernames separated by commas
# Whitelisted users can use restricted commands:
#   $tphere  - Teleport bot to player
#   $exec    - Execute custom commands as the bot
# Example: WHITELIST_USERS=Player1,Player2,Owner
WHITELIST_USERS=YourName
